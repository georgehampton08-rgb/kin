# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://kinuser:kinpass@localhost:5432/kindb

# ── MQTT Broker ───────────────────────────────────────────────────────────────
# Required in production (no default). Set to your MQTT broker hostname or IP.
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_HOST=localhost
# MQTT_PASSWORD: Set via GCP Secret Manager in production, optional locally.
MQTT_PASSWORD=

# ── Security — Secrets ────────────────────────────────────────────────────────
# In PRODUCTION these MUST be set via GCP Secret Manager.
# The app will REFUSE TO START if these are missing in production.
# For LOCAL DEVELOPMENT ONLY, set them here or rely on dev defaults (insecure).
#
# JWT_SECRET_KEY: 256-bit key used to sign all JWT tokens.
#   GCP Secret Manager ID: jwt-secret-key
JWT_SECRET_KEY=
#
# PGCRYPTO_KEY: Symmetric key for pgcrypto encryption of location data.
#   GCP Secret Manager ID: pgcrypto-key
PGCRYPTO_KEY=

# ── GCP Configuration ────────────────────────────────────────────────────────
# Required for GCP Secret Manager integration. Set to your GCP project ID.
GCP_PROJECT_ID=

# ── App Config ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_VERSION=local

# ── Content Security Policy ──────────────────────────────────────────────────
# Override the default CSP policy. Default is strict: default-src 'self'
# Example for development:
#   CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' ws: wss:; frame-ancestors 'none'
CSP_POLICY=

# ── Redis (Rate Limiting) ────────────────────────────────────────────────────
# If set, rate limiting uses Redis. If empty, falls back to in-memory (dev only).
# Format: redis://host:port/db  or  redis://:password@host:port/db
REDIS_URL=

# ── Public API URL (for QR code pairing) ──────────────────────────────────────
KIN_API_URL=http://localhost:8000
